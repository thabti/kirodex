{
  "name": "kirodex",
  "version": "0.8.4",
  "author": "Sabeur Thabti",
  "private": true,
  "scripts": {
    "dev": "cargo tauri dev",
    "dev:renderer": "vite",
    "build": "cargo tauri build",
    "build:renderer": "vite build",
    "check": "npm run check:ts && npm run check:rust",
    "check:ts": "tsc --noEmit",
    "check:rust": "cd src-tauri && cargo check",
    "check:web": "tsc --noEmit && vite build",
    "test:rust": "cd src-tauri && cargo test",
    "test:ui": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test": "vitest run && cd src-tauri && cargo test",
    "build:rust": "cd src-tauri && cargo build",
    "build:rust:release": "cd src-tauri && cargo build --release",
    "package": "cargo tauri build",
    "clean": "rm -rf dist && cd src-tauri && cargo clean",
    "bump": "bash scripts/bump-version.sh",
    "bump:patch": "bash scripts/bump-version.sh patch",
    "bump:minor": "bash scripts/bump-version.sh minor",
    "bump:major": "bash scripts/bump-version.sh major",
    "release": "bash scripts/release.sh"
  },
  "dependencies": {
    "@fontsource-variable/dm-sans": "^5.2.8",
    "@pierre/diffs": "^1.1.12",
    "@tabler/icons-react": "^3.41.1",
    "@tanstack/react-virtual": "^3.13.23",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-store": "^2.4.2",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@xterm/addon-fit": "^0.11.0",
    "diff": "^8.0.4",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "xterm": "^5.3.0"
  },
  "devDependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.0.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/diff": "^8.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "@vitest/coverage-v8": "^4.1.4",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "jsdom": "^29.0.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.0",
    "rolldown-vite": "^7.3.1",
    "tailwind-merge": "^2.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.4",
    "zustand": "^5.0.0"
  },
  "overrides": {
    "vite": "npm:rolldown-vite@latest"
  }
}
